/* ---- DHT22 Start ---- */
uint8_t DHT22_Start(void)
{
    uint8_t response = 0;
    uint32_t timeout;

    /* MCU pulls line LOW for 1-2ms */
    Set_Pin_Output();
    HAL_GPIO_WritePin(GPIOE, Sensor_data_Pin, GPIO_PIN_RESET);
    HAL_Delay(2);

    /* Release line */
    HAL_GPIO_WritePin(GPIOE, Sensor_data_Pin, GPIO_PIN_SET);
    delay_us(40);

    Set_Pin_Input();

    /* 1️⃣ Wait for sensor to pull LOW */
    timeout = 100000;
    while (HAL_GPIO_ReadPin(GPIOE, Sensor_data_Pin))
    {
        if (--timeout == 0) return 0;
    }

    /* 2️⃣ Wait for sensor to pull HIGH */
    timeout = 100000;
    while (!HAL_GPIO_ReadPin(GPIOE, Sensor_data_Pin))
    {
        if (--timeout == 0) return 0;
    }

    response = 1;

    return response;
}

/* ---- Read Byte ---- */
uint8_t DHT22_Read(void)
{
    uint8_t i, result = 0;
    uint32_t start, width;
    uint32_t timeout;

    for (i = 0; i < 8; i++)
    {
        /* Wait for LOW (start of bit) */
        timeout = 100000;
        while (HAL_GPIO_ReadPin(Sensor_data_GPIO_Port, Sensor_data_Pin))
        {
            if (--timeout == 0) return 0;
        }

        /* Wait for HIGH (bit starts) */
        timeout = 100000;
        while (!HAL_GPIO_ReadPin(Sensor_data_GPIO_Port, Sensor_data_Pin))
        {
            if (--timeout == 0) return 0;
        }

        /* Small stabilization delay */
        delay_us(10);


        __HAL_TIM_SET_COUNTER(&htim3, 0);

        while (HAL_GPIO_ReadPin(Sensor_data_GPIO_Port, Sensor_data_Pin))
        {
            if (--timeout == 0) break;
        }

        width = __HAL_TIM_GET_COUNTER(&htim3);

        /* Threshold tuned */
        if (width > 40)   // IMPORTANT: 35 works better than 50
        {
            result |= (1 << (7 - i));
        }
    }

    return result;
}
