/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_ETH_Init();
  MX_USART3_UART_Init();
  MX_USB_OTG_FS_PCD_Init();
  MX_CAN1_Init();
  MX_TIM3_Init();
  /* USER CODE BEGIN 2 */

  HAL_TIM_Base_Start(&htim3);


  HAL_UART_Transmit(&huart3,
                    (uint8_t*)"UART Working\r\n",
                    15,
                    100);

  /* Configure CAN Filter */
  CAN_FilterTypeDef filter;

  filter.FilterBank = 0;
  filter.FilterMode = CAN_FILTERMODE_IDMASK;
  filter.FilterScale = CAN_FILTERSCALE_32BIT;
  filter.FilterIdHigh = 0x0000;
  filter.FilterIdLow = 0x0000;
  filter.FilterMaskIdHigh = 0x0000;
  filter.FilterMaskIdLow = 0x0000;
  filter.FilterFIFOAssignment = CAN_FILTER_FIFO0;
  filter.FilterActivation = ENABLE;

  HAL_CAN_ConfigFilter(&hcan1, &filter);

  HAL_CAN_Start(&hcan1);     // start CAN

  HAL_CAN_ActivateNotification(&hcan1,
      CAN_IT_TX_MAILBOX_EMPTY);



  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */

	  if (DHT22_Start())
	      {

		  HAL_UART_Transmit(&huart3,
		  (uint8_t*)"Start OK\r\n", 10, 100);

	          for (int i = 0; i < 5; i++)
	              dht_data[i] = DHT22_Read();

	          /* ===== ADD DEBUG PRINT HERE ===== */

	          char debugBuf[100];

	          sprintf(debugBuf,
	                  "RAW: %d %d %d %d %d\r\n",
	                  dht_data[0],
	                  dht_data[1],
	                  dht_data[2],
	                  dht_data[3],
	                  dht_data[4]);

	          HAL_UART_Transmit(&huart3,
	                            (uint8_t*)debugBuf,
	                            strlen(debugBuf),
	                            100);

	          /* CHECKSUM VALIDATION */
	          uint8_t sum = dht_data[0] + dht_data[1] + dht_data[2] + dht_data[3];

	          	  if (dht_data[4] == sum)

	             {
	                 humidity = ((dht_data[0] << 8) | dht_data[1]) * 0.1;
	                 temperature = ((dht_data[2] << 8) | dht_data[3]) * 0.1;
	             }
	             else
	             {
	                 HAL_UART_Transmit(&huart3,
	                     (uint8_t*)"Checksum Error\r\n", 16, 100);
	             }

	          /* ---- ADD THIS UART PRINT BLOCK HERE ---- */

	          char uartBuffer[60];

	          sprintf(uartBuffer, "Temp = %.1f C  |  Hum = %.1f %%\r\n",
	                  temperature, humidity);

	          HAL_UART_Transmit(&huart3,
	                            (uint8_t*)uartBuffer,
	                            strlen(uartBuffer),
	                            100);

	          /* ---- Send via CAN ---- */
	          /* -------- Send Temperature -------- */


	              CAN_TxHeaderTypeDef TxHeader;
	              uint32_t TxMailbox;
	              //uint8_t TxData[4];

	              TxHeader.StdId = 0x123;
	              TxHeader.IDE = CAN_ID_STD;
	              TxHeader.RTR = CAN_RTR_DATA;
	              TxHeader.DLC = 4;
	              TxHeader.TransmitGlobalTime = DISABLE;

	              temp = temperature * 10;
	              hum  = humidity * 10;

	              TxData[0] = temp >> 8;
	              TxData[1] = temp;
	              TxData[2] = hum >> 8;
	              TxData[3] = hum;

	              if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan1) > 0)
	              {
	                  HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox);
	              }

	      HAL_Delay(5000);   // DHT22 requires 2 sec delay
	      }
	  else
	  	  {
	  	      HAL_UART_Transmit(&huart3,
	  	          (uint8_t*)"Start FAIL\r\n", 12, 100);
	  	  }
  }
  /* USER CODE END 3 */
}

